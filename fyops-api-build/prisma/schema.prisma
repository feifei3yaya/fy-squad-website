generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  username              String    @unique
  email                 String    @unique
  emailVerified         Boolean   @default(false) @map("email_verified")
  emailVerificationCode String?   @map("email_verification_code")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  passwordHash          String    @map("password_hash")
  role                  String    @default("owner")
  subscriptionTier      String    @default("free") @map("subscription_tier")
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  serverGroups ServerGroup[]
  servers      Server[]
  auditLogs    AuditLog[]
  bans         Ban[]
  vipMembers   VipMember[]
  cdkCodes     CdkCode[]

  @@map("users")
}

model ServerGroup {
  id          String   @id @default(uuid())
  name        String
  ownerId     String   @map("owner_id")
  region      String?
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  owner   User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  servers Server[]

  @@map("server_groups")
}

model Server {
  id              String    @id @default(uuid())
  groupId         String?   @map("group_id")
  ownerId         String    @map("owner_id")
  name            String
  host            String
  queryPort       Int       @default(27165) @map("query_port")
  rconPort        Int       @default(21114) @map("rcon_port")
  rconPassword    String    @map("rcon_password")
  logDir          String?   @map("log_dir")
  maxPlayers      Int       @default(100) @map("max_players")
  status          String    @default("offline")
  currentMap      String?   @map("current_map")
  currentPlayers  Int       @default(0) @map("current_players")
  currentLayer    String?   @map("current_layer")
  gameMode        String?   @map("game_mode")
  version         String?
  lastSeenAt      DateTime? @map("last_seen_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  group          ServerGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  auditLogs      AuditLog[]
  bans           Ban[]
  vipMembers     VipMember[]
  serverMetrics  ServerMetric[]
  playerSessions PlayerSession[]
  chatLogs       ChatLog[]

  @@map("servers")
}

model Player {
  id                String   @id @default(uuid())
  steamId           String   @unique @map("steam_id")
  eosId             String?  @map("eos_id")
  username          String?
  firstSeenAt       DateTime @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime? @map("last_seen_at")
  playTimeMinutes   Int      @default(0) @map("play_time_minutes")
  kills             Int      @default(0)
  deaths            Int      @default(0)
  teamkills         Int      @default(0)
  wounds            Int      @default(0)
  revived           Int      @default(0)

  bans           Ban[]
  vipMembers     VipMember[]
  playerSessions PlayerSession[]
  chatLogs       ChatLog[]
  cdkRedeems     CdkRedeem[]

  @@map("players")
}

model Ban {
  id         String    @id @default(uuid())
  serverId   String    @map("server_id")
  playerId   String?   @map("player_id")
  steamId    String    @map("steam_id")
  eosId      String?   @map("eos_id")
  username   String?
  reason     String?
  bannedBy   String?   @map("banned_by")
  bannedAt   DateTime  @default(now()) @map("banned_at")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  isGlobal   Boolean   @default(false) @map("is_global")

  server Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [bannedBy], references: [id])

  @@index([steamId])
  @@index([isActive])
  @@map("bans")
}

model VipMember {
  id        String   @id @default(uuid())
  playerId  String   @map("player_id")
  serverId  String   @map("server_id")
  tier      String   @default("vip")
  expiresAt DateTime @map("expires_at")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  server Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [createdBy], references: [id])

  @@index([playerId])
  @@index([serverId])
  @@map("vip_members")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  serverId   String?  @map("server_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  details    String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  server Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([serverId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ServerMetric {
  id              String   @id @default(uuid())
  serverId        String   @map("server_id")
  timestamp       DateTime @default(now())
  playerCount     Int      @default(0) @map("player_count")
  fps             Float?
  tickRate        Float?   @map("tick_rate")
  memoryUsageMb   Int?     @map("memory_usage_mb")
  cpuUsagePercent Float?   @map("cpu_usage_percent")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
  @@map("server_metrics")
}

model PlayerSession {
  id              String    @id @default(uuid())
  serverId        String    @map("server_id")
  playerId        String    @map("player_id")
  steamId         String    @map("steam_id")
  username        String?
  teamId          Int?      @map("team_id")
  squadId         Int?      @map("squad_id")
  joinedAt        DateTime  @default(now()) @map("joined_at")
  leftAt          DateTime? @map("left_at")
  playTimeMinutes Int?      @map("play_time_minutes")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([playerId])
  @@map("player_sessions")
}

model ChatLog {
  id        String   @id @default(uuid())
  serverId  String   @map("server_id")
  playerId  String?  @map("player_id")
  steamId   String?  @map("steam_id")
  username  String?
  chatType  String   @map("chat_type")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  server Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([serverId, createdAt])
  @@map("chat_logs")
}

model CdkCode {
  id         String    @id @default(uuid())
  code       String    @unique
  tier       String
  durationDays Int     @map("duration_days")
  maxUses    Int       @default(1) @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  expiresAt  DateTime? @map("expires_at")
  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User?       @relation(fields: [createdBy], references: [id])
  cdkRedeems CdkRedeem[]

  @@map("cdk_codes")
}

model CdkRedeem {
  id          String   @id @default(uuid())
  cdkId       String   @map("cdk_id")
  playerId    String   @map("player_id")
  steamId     String   @map("steam_id")
  redeemedAt  DateTime @default(now()) @map("redeemed_at")

  cdk    CdkCode @relation(fields: [cdkId], references: [id], onDelete: Cascade)
  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("cdk_redeems")
}
